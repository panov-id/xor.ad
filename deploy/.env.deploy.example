# Deploy config for the panov.id group (xor.ad + neighbro.place + sosed.place).
# Copy to deploy/.env.deploy and fill in. Gitignored — holds real tokens/keys.
#
# This file feeds the DNS / go-live / email tooling in deploy/ and the CI token.
# The relay node-pool's own infra creds live separately in
#   relay/wizard/secrets.env   (Hetzner, Bunny storage, GHCR, SESSION_SECRET,
#                                RESEND_KEYS = per-brand sender keys, …).
# Backend = the relay pool (api.relay.panov.id). Supabase is fully decommissioned.

############ GitHub ############
# Fine-grained PAT on panov-id/{xor.ad,neighbro.place,sosed.place} with:
#   Environments: read+write · Secrets: read+write · Contents: read+write
# (Contents write is needed to publish relay releases + prod-dispatch deploys.)
GITHUB_TOKEN=

############ Bunny.net ############
# Account API key (Dashboard → Account → API Key) — cache purge, DNS zone,
# Storage/Pull-zone management, TLS (loadFreeCertificate/ForceSSL) on go-live.
BUNNY_API_KEY=

############ Namecheap (DNS for go-live + panov.id subdomains) ############
# Enable API Access (Profile → Tools → Namecheap API Access) and whitelist your
# public IP. deploy/golive-*-dns.py + namecheap-*.py read these.
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=          # usually the same as NAMECHEAP_API_USER
NAMECHEAP_CLIENT_IP=         # your Namecheap-whitelisted public IP (blank = auto-detect)
NAMECHEAP_SANDBOX=false      # true to hit the sandbox API

############ Resend (transactional email — one account per domain) ############
# Free tier = 1 verified domain per account, so each sending domain has its own
# account + "Full access" key (the key adds/verifies the domain via the API and
# sends mail). The relay picks the key PER BRAND from relay/wizard/secrets.env's
# RESEND_KEYS (e.g. {"neighbro":"re_…","sosed":"re_…"}); paste the same values here
# so the domain-setup scripts (deploy/namecheap-add.py) can create DKIM/SPF.
#
#   Domain          Sends as                 Key
#   ------          --------                 ---
#   neighbro.place  hello@neighbro.place     RESEND_NEIGHBRO_KEY
#   sosed.place     hey@sosed.place          RESEND_SOSED_KEY
#   panov.id        panel@panov.id (panel)   RESEND_PANOV_KEY   (relay default/fallback + panel magic-link)
RESEND_NEIGHBRO_KEY=
RESEND_SOSED_KEY=
RESEND_PANOV_KEY=

############ ImprovMX (MX-based inbound forwarding — one account per domain) ############
# improvmx.com → Account → API → Create API key. Adds the domain + address
# forwards via the API (HTTP Basic: user "api", password = this key).
IMPROVMX_NEIGHBRO_KEY=       # neighbro.place — forwards hello@/support@
IMPROVMX_SOSED_KEY=          # sosed.place    — forwards hey@/support@ (if used)
IMPROVMX_PANOV_KEY=          # panov.id       — forwards dev@/eugene@/eva@/yana@/nikolai@/…

############ Production hostnames ############
PANEL_URL=https://xor.panov.id
SOSED_URL=https://sosed.place
NEIGHBRO_URL=https://neighbro.place

############ Bunny per-target zones (optional; legacy manual fallback) ############
# The landings/panel deploy from GitHub env secrets (set via the wizard), so
# these are only needed for manual local deploys. Storage Zone → FTP & API Access.
# BUNNY_SOSED_STORAGE_ZONE=       BUNNY_SOSED_STORAGE_KEY=       BUNNY_SOSED_PULL_ZONE_ID=
# BUNNY_NEIGHBRO_STORAGE_ZONE=    BUNNY_NEIGHBRO_STORAGE_KEY=    BUNNY_NEIGHBRO_PULL_ZONE_ID=
# BUNNY_PANEL_STORAGE_ZONE=       BUNNY_PANEL_STORAGE_KEY=       BUNNY_PANEL_PULL_ZONE_ID=
