# Production deploy config for xor.ad. Copy to deploy/.env.deploy and fill in.
# This file is gitignored — it holds real tokens and keys.

############ Supabase Cloud ############
# Management API personal access token (Supabase dashboard → Account → Access Tokens).
SUPABASE_ACCESS_TOKEN=

# Filled in by deploy/setup-supabase-cloud.sh after the project is created,
# or paste from an existing project (Dashboard → Project Settings → API).
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# DB password used when creating the project (keep it if you created it here).
SUPABASE_DB_PASSWORD=

############ Bunny.net ############
# Account API key (Dashboard → Account → API Key) — used for cache purge.
BUNNY_API_KEY=

# Per-target Storage Zone name + password (Storage Zone → FTP & API Access),
# and the numeric Pull Zone ID (Pull Zone → General) for cache purge.
BUNNY_SOSED_STORAGE_ZONE=
BUNNY_SOSED_STORAGE_KEY=
BUNNY_SOSED_PULL_ZONE_ID=

BUNNY_NEIGHBRO_STORAGE_ZONE=
BUNNY_NEIGHBRO_STORAGE_KEY=
BUNNY_NEIGHBRO_PULL_ZONE_ID=

BUNNY_PANEL_STORAGE_ZONE=
BUNNY_PANEL_STORAGE_KEY=
BUNNY_PANEL_PULL_ZONE_ID=

############ Production hostnames ############
# Used for the panel Auth redirect allow-list and its build-time Supabase env.
PANEL_URL=https://panel.xor.ad
SOSED_URL=https://sosed.place
NEIGHBRO_URL=https://neighbro.place

############ Wizard inputs (dev/uat/prod provisioning) ############
# The wizard needs these four; deploy/run-wizard.sh feeds them from here.
#   SUPABASE_ACCESS_TOKEN  (above)  — Supabase Management API token
#   SUPABASE_PROJECT_REF   (above)  — shared project ref
#   BUNNY_API_KEY          (above)  — Bunny Account API key
# GitHub PAT with Environments + Secrets write on panov-id/{sosed.place,neighbro.place,xor.ad}.
GITHUB_TOKEN=

############ Namecheap (auto-DNS for panov.id dev/uat) ############
# Enable API Access (Namecheap → Profile → Tools → API Access) and whitelist your
# public IP. deploy/namecheap-dns.sh reads these to add CNAMEs for the dev/uat hostnames.
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=          # usually the same as NAMECHEAP_API_USER
NAMECHEAP_CLIENT_IP=         # your whitelisted public IP (blank = auto-detect)
NAMECHEAP_SANDBOX=false      # true to hit the sandbox API

############ Resend (transactional email) ############
# Resend free tier = 1 domain per account, so we use TWO accounts:
#   Account 1 → panov.id       → panel auth SMTP (later)          → RESEND_API_KEY
#   Account 2 → neighbro.place → client emails (waitlist welcome) → RESEND_NEIGHBRO_KEY
# Use a "Full access" key: it can create/verify the domain via the API (needed
# for deploy/namecheap-add.py to add DKIM/SPF/MX) and also works as the sending key.
RESEND_API_KEY=              # account 1 (panov.id)
RESEND_NEIGHBRO_KEY=         # account 2 (neighbro.place) — for send-waitlist-welcome

# Optional overrides for the welcome email (else sensible defaults are used):
# WELCOME_FROM=Neighbro <hello@neighbro.place>
# WELCOME_SECRET=            # shared secret guarding the send-waitlist-welcome fn (auto-generated if blank)
