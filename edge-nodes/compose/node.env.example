# Per-node environment. The wizard renders the real node.env from the inventory
# + secrets and copies it to the VPS. Never commit the real file.
NODE_ENV_NAME=dev
NODE_ID=n1
NODE_REGION=eu-central
NODE_ROLE=relay
PORT=8080

# Landing faces allowed to call this node (CORS).
ALLOWED_ORIGINS=https://dev.sosed.panov.id,https://dev.neighbro.panov.id

# Bunny Storage (v1 store: waitlist + client errors).
BUNNY_STORAGE_HOST=storage.bunnycdn.com
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_KEY=

# Resend (welcome email).
RESEND_API_KEY=
WELCOME_FROM=sosed <hey@sosed.place>

# TLS hostname for Caddy (this node's own public hostname).
NODE_HOSTNAME=n1.sosed.panov.id
